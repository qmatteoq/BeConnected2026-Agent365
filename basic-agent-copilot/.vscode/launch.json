{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run with Dev Tunnel",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-and-tunnel",
      "program": "${workspaceFolder}/bin/Debug/net10.0/basic-agent-copilot.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Production",
        "ASPNETCORE_URLS": "http://localhost:5130"
      },
      "console": "internalConsole"
    }
  ]
}
