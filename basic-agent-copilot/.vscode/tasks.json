{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/basic-agent-copilot.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "start-devtunnel",
      "detail": "Hosts the zava-weather-agent dev tunnel (port 5130)",
      "type": "shell",
      "command": "devtunnel",
      "args": [
        "host",
        "zava-weather-agent"
      ],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      },
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Hosting tunnel",
            "endsPattern": "Ready to accept connections|Connect via browser"
          }
        }
      ]
    },
    {
      "label": "build-and-tunnel",
      "dependsOn": [
        "build",
        "start-devtunnel"
      ],
      "dependsOrder": "sequence"
    }
  ]
}
