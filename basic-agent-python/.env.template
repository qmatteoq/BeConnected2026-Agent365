# Azure OpenAI endpoint (no trailing slash needed)
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/

# Model deployment name
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1

# Azure OpenAI API version used by the AzureChatOpenAI client
AZURE_OPENAI_API_VERSION=2024-10-21
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
AGENT_ID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SCOPES=<your-scope-guid>/.default
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__TYPE=AgenticUserAuthorization
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__ALT_BLUEPRINT_NAME=SERVICE_CONNECTION
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__SCOPES=https://graph.microsoft.com/.default
CONNECTIONSMAP__0__SERVICEURL=*
CONNECTIONSMAP__0__CONNECTION=SERVICE_CONNECTION
ENABLE_A365_OBSERVABILITY_EXPORTER=true
AGENT365OBSERVABILITY__AGENTID=
AGENT365OBSERVABILITY__AGENTNAME=
AGENT365OBSERVABILITY__AGENTDESCRIPTION=
AGENT365OBSERVABILITY__TENANTID=
AGENT365OBSERVABILITY__AGENTBLUEPRINTID=
AGENT365OBSERVABILITY__CLIENTID=
AGENT365OBSERVABILITY__CLIENTSECRET=

# ── Agent 365 Observability (S2S) ───────────────────────────────────────────
# BOTH ENABLE_A365_OBSERVABILITY_EXPORTER and ENABLE_A365_OBSERVABILITY must be
# true for the Python SDK to actually create + export spans.
ENABLE_A365_OBSERVABILITY=true
AGENT365_TENANT_ID=
AGENT365_AGENT_ID=
AGENT365_BLUEPRINT_ID=
AGENT365_CLIENT_ID=
AGENT365_CLIENT_SECRET=
AGENT365_AGENT_NAME=<your-agent-name>
AGENT365_AGENT_DESCRIPTION=<your-agent-description>
AGENT365_USE_MANAGED_IDENTITY=false
AGENT365_USE_S2S_ENDPOINT=true
# Sponsor identity for CallerDetails (required for MAC portal visibility)
AGENT365_SPONSOR_USER_ID=
AGENT365_SPONSOR_USER_EMAIL=
AGENT365_SPONSOR_USER_NAME=

# Service identity stamped onto every span/metric/log resource. Without these,
# telemetry shows up in Aspire / Defender as "unknown_service:python". The
# microsoft-opentelemetry distro honors the standard OTel env vars and merges
# them into the Resource — no code change required.
OTEL_SERVICE_NAME=basic-agent-python
OTEL_RESOURCE_ATTRIBUTES=service.namespace=Microsoft.Agents,service.version=1.0.0,service.instance.id=local-dev,deployment.environment=Development,microsoft.tenant.id=<your-tenant-id>,microsoft.a365.agent.id=<your-agent-id>,microsoft.a365.agent.blueprint.id=<your-blueprint-id>
